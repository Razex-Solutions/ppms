DATABASE_URL=sqlite:///./ppms.db
SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=14
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
ENABLED_MODULES=*
APP_ENV=development
LOG_LEVEL=INFO

DELIVERY_MODE=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=

DELIVERY_WORKER_ENABLED=false
DELIVERY_WORKER_INTERVAL_SECONDS=30
BACKUP_DIRECTORY=./backups
BACKUP_RETENTION_COUNT=10

ONLINE_HOOKS_MODE=mock
HARDWARE_VENDOR_MODE=mock
PPMS_DESKTOP_API_BASE_URL=http://127.0.0.1:8012
