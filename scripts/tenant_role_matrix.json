{
  "version": 1,
  "purpose": "Machine-readable Phase 9 tenant Flutter role/screen/API contract.",
  "rules": {
    "single_station_tenant": "HeadOffice acts as both organization admin and station admin; StationAdmin is hidden.",
    "multi_station_tenant": "HeadOffice can see tenant stations; StationAdmin is station-scoped.",
    "platform_scope": "MasterAdmin stays outside the tenant Flutter app."
  },
  "roles": {
    "HeadOffice": {
      "screens": {
        "tenant_setup": {
          "visible": true,
          "read_apis": [
            "GET /organizations/{organization_id}/setup-foundation"
          ]
        },
        "users": {
          "visible": true,
          "read_apis": [
            "GET /users/?organization_id={organization_id}",
            "GET /roles/"
          ],
          "create_apis": [
            "POST /users/"
          ],
          "update_apis": [
            "PUT /users/{user_id}"
          ],
          "delete_apis": [
            "DELETE /users/{user_id}"
          ],
          "notes": "Create StationAdmin only for multi-station tenants; create Manager, Accountant, Operator for one-station tenants."
        },
        "station_setup": {
          "visible": true,
          "read_apis": [
            "GET /stations/{station_id}/setup-foundation"
          ]
        },
        "tankers": {
          "visible_when_modules": [
            "tanker_operations"
          ],
          "read_apis": [
            "GET /tankers/?station_id={station_id}",
            "GET /tankers/trips?station_id={station_id}"
          ]
        },
        "pos": {
          "visible_when_modules": [
            "pos",
            "mart"
          ],
          "read_apis": [
            "GET /pos-products/?station_id={station_id}",
            "GET /pos-sales/?station_id={station_id}"
          ],
          "create_apis": [
            "POST /pos-products/",
            "POST /pos-sales/"
          ]
        },
        "reports": {
          "visible": true,
          "read_apis": [
            "GET /reports/daily-closing?report_date={today}&station_id={station_id}",
            "GET /report-definitions/",
            "GET /report-exports/"
          ],
          "create_apis": [
            "POST /report-exports/"
          ]
        },
        "documents": {
          "visible": true,
          "read_apis": [
            "GET /document-templates/{station_id}",
            "GET /financial-documents/dispatches",
            "GET /financial-documents/dispatches/diagnostics"
          ]
        },
        "notifications": {
          "visible": true,
          "read_apis": [
            "GET /notifications/summary",
            "GET /notifications/",
            "GET /notifications/deliveries",
            "GET /notifications/preferences"
          ],
          "create_apis": [
            "POST /notifications/read-all"
          ],
          "update_apis": [
            "PUT /notifications/preferences/report_export.completed"
          ]
        },
        "inventory": {
          "visible": true,
          "read_apis": [
            "GET /stations/{station_id}/setup-foundation"
          ]
        }
      }
    },
    "StationAdmin": {
      "screens": {
        "users": {
          "visible": true,
          "read_apis": [
            "GET /users/?station_id={station_id}",
            "GET /roles/"
          ],
          "create_apis": [
            "POST /users/"
          ],
          "update_apis": [
            "PUT /users/{user_id}"
          ],
          "delete_apis": [
